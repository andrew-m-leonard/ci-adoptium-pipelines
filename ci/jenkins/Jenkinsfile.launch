/**
 * Launch Pipeline for OpenJDK Builds
 *
 * This pipeline orchestrates builds across multiple platforms for a specific JDK version.
 * It dynamically creates platform-specific build jobs and launches them in parallel.
 *
 * Job Name Pattern: jdk${version}-launch-build-pipelines
 * Creates: jdk${version}-${platform}-build-pipeline jobs
 */

import groovy.json.JsonSlurper

pipeline {
    agent any
    
    // NOTE: Parameters and build discarder are defined by the seed job via Job DSL, not here.
    // Defining them in the Jenkinsfile would override the seed job's settings.
    // See: ci/jenkins/job-dsl/seed/seed_job_consolidated.groovy
    
    options {
        timestamps()
        timeout(time: params.PIPELINE_TIMEOUT_HOURS?.toInteger() ?: 8, unit: 'HOURS')
    }
    
    stages {
        stage('Initialize') {
            steps {
                script {
                    // Use JDK_VERSION parameter (set by seed job)
                    env.JDK_VERSION = params.JDK_VERSION
                    
                    echo "=== Launch Pipeline for JDK ${env.JDK_VERSION} ==="
                    echo "Configuration Repository: ${params.CONFIG_REPO_URL}"
                    echo "Configuration Branch: ${params.CONFIG_REPO_BRANCH}"
                    echo "Regenerate Jobs: ${params.REGENERATE_JOBS}"
                    echo "Platforms: ${params.PLATFORMS}"
                }
            }
        }
        
        stage('Fetch Configuration') {
            steps {
                script {
                    echo "Fetching configuration for JDK ${env.JDK_VERSION}..."
                    echo "  Repository: ${params.CONFIG_REPO_URL}"
                    echo "  Branch: ${params.CONFIG_REPO_BRANCH}"
                    
                    def configFile = "configurations/jdk${env.JDK_VERSION}_pipeline_config.json"
                    
                    // Checkout configuration repository
                    dir('config-repo') {
                        git url: params.CONFIG_REPO_URL, branch: params.CONFIG_REPO_BRANCH
                        
                        // Read configuration file
                        if (!fileExists(configFile)) {
                            error("Configuration file not found: ${configFile}\n\nEnsure the file exists in the configuration repository.")
                        }
                        
                        def configText = readFile(configFile)
                        env.VERSION_CONFIG = configText
                        def config = new JsonSlurper().parseText(configText)
                        
                        // Extract platform list from buildConfigurations keys
                        def platforms = config.buildConfigurations.keySet() as List
                        env.AVAILABLE_PLATFORMS = platforms.join(',')
                        
                        echo "✓ Configuration loaded successfully"
                        echo "  Available platforms: ${env.AVAILABLE_PLATFORMS}"
                    }
                }
            }
        }
        
        stage('Determine Platforms') {
            steps {
                script {
                    def availablePlatforms = env.AVAILABLE_PLATFORMS.split(',') as List
                    def selectedPlatforms
                    
                    if (params.PLATFORMS == 'all') {
                        selectedPlatforms = availablePlatforms
                        echo "Building all available platforms"
                    } else {
                        selectedPlatforms = params.PLATFORMS.split(',').collect { it.trim() }
                        
                        // Validate selected platforms
                        def invalidPlatforms = selectedPlatforms.findAll { !availablePlatforms.contains(it) }
                        if (invalidPlatforms) {
                            error("Invalid platforms specified: ${invalidPlatforms.join(', ')}\nAvailable platforms: ${availablePlatforms.join(', ')}")
                        }
                        echo "Building selected platforms: ${selectedPlatforms.join(', ')}"
                    }
                    
                    env.SELECTED_PLATFORMS = selectedPlatforms.join(',')
                    echo "✓ Platforms determined: ${env.SELECTED_PLATFORMS}"
                }
            }
        }
        
        stage('Create/Update Platform Jobs') {
            when {
                expression {
                    // Create jobs on first run or when explicitly requested
                    // Note: If platform jobs are deleted later, set REGENERATE_JOBS=true to recreate them
                    return params.REGENERATE_JOBS || currentBuild.number == 1
                }
            }
            steps {
                script {
                    if (params.REGENERATE_JOBS) {
                        echo "Force regenerating platform jobs (REGENERATE_JOBS=true)..."
                    } else {
                        echo "First run - creating platform jobs..."
                    }
                    
                    def platforms = env.SELECTED_PLATFORMS.split(',')
                    
                    platforms.each { platform ->
                        def jobName = "/openjdk-builds/jdk${env.JDK_VERSION}/jdk${env.JDK_VERSION}-${platform}-build-pipeline"
                        echo "  → Creating/updating: ${jobName}"
                        
                        // Use Job DSL to create/update the job
                        // IMPORTANT: Use ignoreMissingFiles and ignoreExisting to prevent modifying this launch job
                        jobDsl(
                            targets: 'ci/jenkins/job-dsl/openjdk_build_pipeline.groovy',
                            removedJobAction: 'IGNORE',
                            removedViewAction: 'IGNORE',
                            ignoreExisting: false,  // Allow updates to existing platform jobs
                            ignoreMissingFiles: false,
                            lookupStrategy: 'SEED_JOB',  // Use seed job's workspace for script lookup
                            additionalParameters: [
                                JDK_VERSION: env.JDK_VERSION,
                                PLATFORM: platform,
                                CONFIG_REPO_URL: params.CONFIG_REPO_URL,
                                CONFIG_REPO_BRANCH: params.CONFIG_REPO_BRANCH
                            ]
                        )
                    }
                    
                    echo "✓ Platform jobs created/updated successfully"
                }
            }
        }
        
        stage('Launch Platform Builds') {
            steps {
                script {
                    echo "Launching builds for selected platforms..."
                    
                    def platforms = env.SELECTED_PLATFORMS.split(',')
                    def buildJobs = [:]
                    def buildResults = [:]
                    
                    platforms.each { platform ->
                        def jobName = "/openjdk-builds/jdk${env.JDK_VERSION}/jdk${env.JDK_VERSION}-${platform}-build-pipeline"
                        
                        buildJobs[platform] = {
                            stage("Build ${platform}") {
                                echo "Launching build for ${platform}..."
                                
                                def buildResult = build(
                                    job: jobName,
                                    parameters: [
                                        string(name: 'JDK_VERSION', value: env.JDK_VERSION),
                                        string(name: 'PLATFORM', value: platform),
                                        string(name: 'BUILD_VARIANT', value: params.BUILD_VARIANT),
                                        string(name: 'CONFIG_REPO_URL', value: params.CONFIG_REPO_URL),
                                        string(name: 'CONFIG_REPO_BRANCH', value: params.CONFIG_REPO_BRANCH),
                                        booleanParam(name: 'CLEAN_WORKSPACE_AFTER_STAGE', value: params.CLEAN_WORKSPACE_AFTER_STAGE),
                                        booleanParam(name: 'RUN_TESTS', value: params.RUN_TESTS),
                                        booleanParam(name: 'SIGN_ARTIFACTS', value: params.SIGN_ARTIFACTS),
                                        booleanParam(name: 'PUBLISH_ARTIFACTS', value: params.PUBLISH_ARTIFACTS),
                                        booleanParam(name: 'RUN_REPRODUCIBLE_COMPARE', value: params.RUN_REPRODUCIBLE_COMPARE)
                                    ],
                                    wait: true,
                                    propagate: false  // Don't fail immediately, collect all results first
                                )
                                
                                buildResults[platform] = buildResult.result
                                echo "✓ ${platform} build completed with result: ${buildResult.result}"
                            }
                        }
                    }
                    
                    // Execute all platform builds in parallel
                    parallel buildJobs
                    
                    // Check if any builds failed
                    def failedBuilds = buildResults.findAll { platform, result -> result != 'SUCCESS' }
                    if (failedBuilds) {
                        def failedPlatforms = failedBuilds.keySet().join(', ')
                        error("Platform builds failed: ${failedPlatforms}")
                    }
                    
                    echo "✓ All platform builds completed successfully"
                }
            }
        }
    }
    
    post {
        always {
            script {
                echo "=== Launch Pipeline Summary ==="
                echo "JDK Version: ${env.JDK_VERSION}"
                echo "Platforms: ${env.SELECTED_PLATFORMS}"
                echo "Build Result: ${currentBuild.result ?: 'SUCCESS'}"
            }
        }
        success {
            echo "✓ Launch pipeline completed successfully"
        }
        failure {
            echo "✗ Launch pipeline failed"
        }
    }
}

