/**
 * Seed Pipeline — template for vendors to copy into their config repo.
 *
 * PURPOSE
 * -------
 * This Jenkinsfile is the entry point for the seed Pipeline job that creates
 * all OpenJDK build launch jobs on a Jenkins instance.  It is intentionally
 * minimal: check out the ci-adoptium-pipelines repo, then run the Job DSL
 * script that generates the launch (and platform build) jobs.
 *
 * All configuration is read directly from files already present in the
 * workspace (adoptium_pipeline_config.json, jenkins_job_config.json,
 * configurations/, vendor-scripts/) — no parameters are required.
 *
 * VENDOR SETUP
 * ------------
 * 1. Copy this file into your vendor config repository:
 *      <config-repo-root>/Jenkinsfile.seed
 *
 * 2. In Jenkins, create a new Pipeline job named "openjdk-build-seed-job".
 *
 * 3. Under "Pipeline":
 *      - Definition : Pipeline script from SCM
 *      - SCM        : Git
 *      - Repository URL : <your config repo URL>
 *      - Credentials    : <Jenkins credential for your config repo if private>
 *      - Branch         : <your config repo branch, e.g. main>
 *      - Script Path    : Jenkinsfile.seed   (or wherever you placed this file)
 *
 * 4. Run the seed job.  It will:
 *      - Check out ci-adoptium-pipelines into a 'pipelines/' subdirectory
 *      - Run the Job DSL script to create all launch jobs, reading all
 *        configuration directly from the workspace
 *
 * CUSTOMISATION
 * -------------
 * - Change PIPELINES_REPO_URL / PIPELINES_REPO_BRANCH below to pin to a
 *   specific fork or branch of ci-adoptium-pipelines.
 * - The Job DSL script reads vendor-scripts/*.params.json from this repo's
 *   workspace (already checked out by the Pipeline SCM step) — no extra
 *   checkout is needed for vendor stage parameter overrides.
 */

// ---------------------------------------------------------------------------
// Configuration — adjust these for your environment
// ---------------------------------------------------------------------------

// ci-adoptium-pipelines repository containing the Job DSL scripts.
// Override these to pin to a fork or specific branch.
def PIPELINES_REPO_URL    = 'https://github.com/adoptium/ci-adoptium-pipelines.git'
def PIPELINES_REPO_BRANCH = 'main'

// ---------------------------------------------------------------------------
// Pipeline
// ---------------------------------------------------------------------------

pipeline {
    agent any

    options {
        timestamps()
        disableConcurrentBuilds()
    }

    stages {
        stage('Checkout pipeline repo') {
            steps {
                // Check out ci-adoptium-pipelines into pipelines/ so that the
                // Job DSL script and stage *.params.json files are available.
                // The vendor config repo is already in the workspace root
                // (checked out by the Pipeline SCM step above).
                dir('pipelines') {
                    git url:    PIPELINES_REPO_URL,
                        branch: PIPELINES_REPO_BRANCH
                }
            }
        }

        stage('Generate jobs') {
            steps {
                // Run the consolidated Job DSL script.
                // All configuration is read from the workspace:
                //   adoptium_pipeline_config.json, jenkins_job_config.json,
                //   configurations/, vendor-scripts/ (config repo, workspace root)
                //   pipelines/scripts/stages/ (default *.params.json)
                jobDsl(
                    targets:              'pipelines/ci/jenkins/job-dsl/seed/seed_job_consolidated.groovy',
                    removedJobAction:     'DELETE',
                    removedViewAction:    'DELETE',
                    additionalClasspath:  'pipelines/ci/jenkins/job-dsl',
                    additionalParameters: [
                        WORKSPACE: env.WORKSPACE
                    ]
                )
            }
        }
    }

    post {
        success { echo '✓ Seed job completed — launch jobs created/updated.' }
        failure { echo '✗ Seed job failed — check the Job DSL output above.' }
    }
}
